
# Set to False for Deployment
DEBUG="True"

# Secret key for Flask session
SECRET_KEY="your-secret-key-goes-here"

# Password for static site generator data fetching
API_PASSWORD="password-here"

# Choose between local SQLite file (from DEV)
# or proper production DB
USE_SQLITE="False"

# Local SQLite database file (used only in dev mode)
SQLITE_FILE="voyage_dev.db"

# Full connection URI for production database (e.g., PostgreSQL)
# This is only used when USE_SQLITE is set to 'False'.
DATABASE_URI=""

# hCaptcha Setup
HCAPTCHA_SITE_KEY=your_hcaptcha_site_key
HCAPTCHA_SECRET_KEY=your_hcaptcha_secret_key
HCAPTCHA_ENABLED=True
# ^ string : True or False


# Google Sheets Ingestion
# Base64 encoded contents of service account key file
GCP_SA_KEY_B64=""
REG_SHEET_KEY=""
CR_PAY_SHEET_KEY=""

# GitHub Actions Trigger
GH_OWNER=""
GH_REPO=""
GH_PAT=""