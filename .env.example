
# Set to False for Deployment
DEBUG="True"

# Secret key for Flask session
SECRET_KEY="your-secret-key-goes-here"

# Choose between local SQLite file (from DEV)
# or proper production DB
USE_SQLITE="False"

# Local SQLite database file (used only in dev mode)
SQLITE_FILE="voyage_dev.db"

# Full connection URI for production database (e.g., PostgreSQL)
# This is only used when USE_SQLITE is set to 'False'.
DATABASE_URI=""